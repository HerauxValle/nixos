# MyBar variable overrides
# Copy this file to ~/.config/mybar/custom/ and uncomment/edit what you want.
# See guides/variables.md for the full reference.

# Layout
#MYBAR_MODE=hanging          # hanging | pill
#MYBAR_POS=top               # top | bottom | left | right
#MYBAR_ALIGN=center          # left | center | right
#MYBAR_PILL_W=1.0            # 0.35 – 1.0
#MYBAR_MARGIN=0              # px gap from screen edge
#MYBAR_HEIGHT=48             # px

# Appearance
#MYBAR_OPACITY=0.72          # 0.4 – 1.0
#MYBAR_UI_SCALE=1.0
#MYBAR_FONT_SIZE=12
#MYBAR_TINT=0                # 0–5 preset index
#MYBAR_ACCENT=#5C8FA5        # custom hex accent

# Notifications
#MYBAR_NOTIF_MAX=3
#MYBAR_DRAWER_MAX=20

# Airplane mode (0/1)
#MYBAR_AP_WIFI=1
#MYBAR_AP_BT=1
#MYBAR_AP_ETH=1
#MYBAR_AP_DAEMONS=0
#MYBAR_AP_FIREWALL=0

# Keybinds (MOD+MOD+KEY)
#MYBAR_BIND_DRAWER=SUPER+B
#MYBAR_BIND_LAUNCHER=SUPER+Space
#MYBAR_BIND_CC=SUPER+C
#MYBAR_BIND_POWER=SUPER+Escape
#MYBAR_BIND_SETTINGS=SUPER+comma
#MYBAR_BIND_NOTIFICATIONS=SUPER+SHIFT+N
#MYBAR_BIND_WIFI=SUPER+SHIFT+W
#MYBAR_BIND_BLUETOOTH=SUPER+SHIFT+B
#MYBAR_BIND_WORKSPACEMENU=SUPER+Tab

# Key capture timers (ms)
#MYBAR_CAPTURE_TIMEOUT=3000
#MYBAR_CAPTURE_GREEN_MS=1200
#MYBAR_CAPTURE_YELLOW_MS=1200
#MYBAR_CAPTURE_CONFLICT_MS=2000
