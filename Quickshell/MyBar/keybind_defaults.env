# MyBar keybind defaults
# These set the DEFAULT binds shown in settings and used on first launch.
# To change a bind permanently after first launch, use the Settings UI instead.
# Copy this file to ~/.config/mybar/custom/ and uncomment what you want to change.

#AETHERA_DEFAULT_DRAWER=SUPER+B
#AETHERA_DEFAULT_LAUNCHER=SUPER+Space
#AETHERA_DEFAULT_CC=SUPER+C
#AETHERA_DEFAULT_POWER=SUPER+Escape
#AETHERA_DEFAULT_SETTINGS=SUPER+comma
#AETHERA_DEFAULT_NOTIFICATIONS=SUPER+SHIFT+N
#AETHERA_DEFAULT_WIFI=SUPER+SHIFT+W
#AETHERA_DEFAULT_BLUETOOTH=SUPER+SHIFT+B
#AETHERA_DEFAULT_WORKSPACEMENU=SUPER+Tab
