#!/usr/bin/env bash
# sudo — single entrypoint.
#
# Normal usage (TTY present):    passes straight through to the real sudo
# Non-interactive (no TTY):      submits a broker request for async human approval
#
# Broker flags (--adv:<name>):
#   --adv:approve [id]         approve latest or specific request
#   --adv:deny    [id]         deny latest or specific request
#   --adv:pending              list all pending requests with age + TTL
#   --adv:live                 watch for requests, interactively approve/deny
#   --adv:install              symlink this script into ~/.local/bin/sudo
#   --adv:uninstall            remove that symlink
#
#   --adv:auto                       toggle auto mode (skip per-command approval)
#   --adv:auto-status                show whether auto mode is on + time left
#   --adv:auto-enable[-<N>-<unit>]   enable (optionally timed), captcha required
#   --adv:auto-session[-<N>-<unit>]  enable for this terminal only
#   --adv:auto-disable               disable auto mode immediately
#
#   --adv:blacklist-add <pattern>    add a pattern never auto-run even in auto mode
#   --adv:blacklist-rem <pattern>    remove a pattern
#   --adv:blacklist-list             show current patterns
#   --adv:blacklist-edit             open blacklist.conf in $EDITOR
#
#   --adv:help                 full usage, including auto mode duration syntax
#
# Note: --adv: prefix is used so broker flags never collide with real sudo flags.

set -euo pipefail

# Fixed, XDG-stable location — not derived from $0 — so lib/*.sh always
# resolves the same way regardless of how/where "sudo" itself is reached
# (a plain symlink, a Nix store copy, whatever). Whatever deploys
# dotfiles on a given system (here: home-manager's "scripts" xdg.configFile
# entry, on rebuild) is responsible for putting Scripts/ here — same as
# any other XDG config dir, Nix or not.
SCRIPT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/scripts/Sudo"
source "$SCRIPT_DIR/lib/common.sh"
source "$SCRIPT_DIR/lib/auto.sh"
source "$SCRIPT_DIR/lib/blacklist.sh"
source "$SCRIPT_DIR/lib/request.sh"
source "$SCRIPT_DIR/lib/approve.sh"
source "$SCRIPT_DIR/lib/deny.sh"
source "$SCRIPT_DIR/lib/pending.sh"
source "$SCRIPT_DIR/lib/live.sh"

# ── install / uninstall ───────────────────────────────────────────────────────

do_install() {
    if grep -qi '^ID=nixos' /etc/os-release 2>/dev/null; then
        echo "NixOS detected — this symlinks $INSTALL_DIR/sudo by hand, outside" >&2
        echo "Nix's management. On NixOS this is normally done declaratively" >&2
        echo "instead (e.g. via home.file), so it's reproducible/rollback-safe." >&2
        local _reply
        read -r -p "Install imperatively anyway? [y/N] " _reply
        case "$_reply" in
            [yY]|[yY][eE][sS]) ;;
            *) echo "Aborted." >&2; return 1 ;;
        esac
    fi

    mkdir -p "$INSTALL_DIR"
    local SRC="$(realpath "$0")"
    local DST="$INSTALL_DIR/sudo"
    ln -sf "$SRC" "$DST"
    echo "Installed: $DST → $SRC"
    echo ""
    echo "Make sure $INSTALL_DIR appears BEFORE /usr/bin in your PATH"
    echo "so this wrapper intercepts 'sudo' before the real one."
    echo ""
    echo "Add to your shell config if needed:"
    echo "  fish:  set -gx PATH $INSTALL_DIR \$PATH"
    echo "  bash:  export PATH=\"$INSTALL_DIR:\$PATH\""
}

do_uninstall() {
    local DST="$INSTALL_DIR/sudo"
    if [[ -L "$DST" && "$(realpath "$DST")" == "$(realpath "$0")" ]]; then
        rm "$DST"
        echo "Removed: $DST"
    else
        echo "Nothing to remove (not our symlink): $DST"
    fi
}

# ── dispatch ──────────────────────────────────────────────────────────────────

case "${1:-}" in
    --adv:approve|--adv:yes|--adv:y)  shift; do_approve "$@" ;;
    --adv:deny|--adv:no|--adv:n)     shift; do_deny    "$@" ;;
    --adv:pending)   do_pending ;;
    --adv:live)      do_live ;;
    --adv:auto-status)    do_auto_status ;;
    --adv:auto-disable)   do_auto_disable ;;
    --adv:auto-session*)  do_auto_session "${1#--adv:auto-session}" ;;
    --adv:auto-enable*)   do_auto_enable "${1#--adv:auto-enable}" ;;
    --adv:auto)           do_auto_toggle ;;
    --adv:blacklist-add) shift; do_blacklist_add "$@" ;;
    --adv:blacklist-rem) shift; do_blacklist_rem "$@" ;;
    --adv:blacklist-list) do_blacklist_list ;;
    --adv:blacklist-edit) do_blacklist_edit ;;
    --adv:install)   do_install ;;
    --adv:uninstall) do_uninstall ;;
    --adv:help)
        cat <<'EOF'
sudo broker — async sudo approval for non-interactive sessions (e.g. AI agents)

When no TTY is detected, sudo queues a request instead of running directly.
A human must approve it from another terminal. With a TTY, sudo passes straight
through to the real sudo — no change in behaviour.

BROKER FLAGS
  sudo --adv:approve [id]         Approve a pending request. Omit id for latest.
  sudo --adv:deny    [id]         Deny a pending request.   Omit id for latest.
  sudo --adv:pending              List all pending requests with age and TTL.
  sudo --adv:live                 Watch for requests and approve/deny interactively.
  sudo --adv:install              Symlink sudo into ~/.local/bin (run once to set up).
  sudo --adv:uninstall            Remove the symlink.
  sudo --adv:help                 Show this help.

AUTO MODE (authenticate once, all broker requests run without approval)
  sudo --adv:auto                          Toggle auto mode on/off (global).
  sudo --adv:auto-status                   Show whether auto mode is on and time remaining.
  sudo --adv:auto-enable                   Enable globally (captcha required, all terminals + no-TTY).
  sudo --adv:auto-enable-no-warning        Enable globally (skip captcha).
  sudo --adv:auto-enable-<N>-<unit>        Enable globally for duration. Units: s m h d
                                           e.g. --adv:auto-enable-12-h
  sudo --adv:auto-enable-<N>-<unit>-no-warning   Same, skip captcha.
  sudo --adv:auto-session                  Enable for THIS terminal only (no sudoers change,
                                           other terminals still need a password).
  sudo --adv:auto-session-<N>-<unit>[-no-warning]   Same, timed / skip captcha.
  sudo --adv:auto-disable                  Disable all auto mode sessions immediately.

  Blacklisted commands (see below) always fall back to a real password
  prompt, even while auto mode is on.

BLACKLIST (commands that always require a password, even in auto mode)
  sudo --adv:blacklist-add <pattern>       Block commands starting with <pattern>.
  sudo --adv:blacklist-rem <pattern>       Remove a pattern.
  sudo --adv:blacklist-list                Show current patterns.
  sudo --adv:blacklist-edit                Open blacklist.conf in $VISUAL/$EDITOR
                                           (falls back to nano/vim/vi/micro).

  The live blacklist lives at $XDG_DATA_HOME/sudo-broker/blacklist.conf
  (usually ~/.local/share/sudo-broker/blacklist.conf) — seeded once from
  Scripts/Sudo/lib/blacklist.conf in the Dotfiles checkout on first use,
  then edited directly from there on, no rebuild needed. Not tracked by
  Nix/Dotfiles itself past that seed, so back it up if you want your
  additions to survive a fresh install (see Scripts/Backup/backup.sh).

ENVIRONMENT
  SUDO_BROKER_TIMEOUT          Seconds before a request is auto-denied. Default: 360.
  SUDO_BROKER_INSTALL_DIR      Where --install places the symlink. Default: ~/.local/bin.
  SUDO_BROKER_BLACKLIST_FILE   Override the live blacklist path. Default:
                              $XDG_DATA_HOME/sudo-broker/blacklist.conf.

TYPICAL WORKFLOW
  Terminal A (AI):    sudo apt install htop
                      → prints request ID + instructions, then blocks

  Terminal B (you):   sudo --adv:approve
                      → runs real sudo here, forwards output back to A

  Or keep Terminal B running:
                      sudo --adv:live
                      → prompts y/N for each incoming request
EOF
        ;;

    "")
        echo "Usage: sudo <command>  or  sudo --adv:help" >&2
        exit 1
        ;;
    --adv:*)
        # Any --adv: flag not matched by a specific case above is a typo/
        # unknown flag, not a real command — falling through to the
        # generic case below would silently hand it to real sudo, which
        # doesn't understand --adv: at all and just prints its own usage.
        echo "Unknown broker flag: $1" >&2
        echo "See: sudo --adv:help" >&2
        exit 1
        ;;
    *)
        # -n means "never prompt/block — fail immediately if a password
        # would be needed" per real sudo's own contract. Queuing a broker
        # request (which blocks awaiting human approval) violates that
        # contract just as much as an interactive password prompt would —
        # so any -n call always goes straight to real sudo, transparently,
        # before any auto-mode/TTY/broker logic runs at all. Without this,
        # anything that does its own `sudo -n ...` liveness check (e.g. the
        # fish prompt's sudo-status indicator, run on every single prompt
        # render) gets treated as a real command needing approval —
        # spamming a broker request on every keystroke.
        for _arg in "$@"; do
            [[ "$_arg" == "-n" ]] && exec "$REAL_SUDO" "$@"
        done

        # Auto mode check — scoped to the current terminal (or global)
        _cur_tty=$(tty 2>/dev/null || echo "")
        if auto_is_active_for_tty "$_cur_tty"; then
            if _bl_match=$(blacklist_check "$@"); then
                echo "[sudo broker] Blacklisted pattern: $_bl_match — password required." >&2
                auto_run_blacklisted "$@"
                exit $?
            else
                exec "$REAL_SUDO" -n "$@"
            fi
        fi
        # TTY present → real sudo, fully transparent
        if [[ -t 0 && -t 1 ]]; then
            exec "$REAL_SUDO" "$@"
        fi
        # No TTY → try NOPASSWD passthrough first; only broker if password is required
        if _nopasswd_out=$("$REAL_SUDO" -n "$@" 2>&1); then
            printf '%s' "$_nopasswd_out"
            exit 0
        else
            _nopasswd_exit=$?
            if echo "$_nopasswd_out" | grep -qiE 'password is required|no tty present'; then
                do_request "$@"
            else
                echo "$_nopasswd_out" >&2
                exit "$_nopasswd_exit"
            fi
        fi
        ;;
esac
